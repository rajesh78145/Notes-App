<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>First</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input name="title" type="text" placeholder="Title"
                    class="w-full rounded-md outline-none block px-5 py-2 bg-zinc-800" />
                <textarea name="details"
                    class="w-full rounded-md outline-none mt-2 block px-5 py-2 resize-none bg-zinc-800"
                    placeholder="Write your notes"></textarea>
                <input class="mt-2 bg-blue-800 px-5 py-2 rounded-md" type="submit" value="Create Task" />
            </form>
        </div>
        <div class="tasks p-10 flex gap-5 flex-wrap">

            <% if (files.length> 0) { %>

                <% files.forEach(function(val) { %>

                    <div class="task w-72 px-3 py-4 bg-zinc-800 rounded-md">
                        <h1 class="text-white text-2xl tracking-tighter">
                            <%= val %>
                        </h1>

                        <a class="text-blue-500 inline-block mt-3" href="/files/<%= val %>">
                            Read more...
                        </a>
                    </div>

                    <% }) %>

                        <% } else { %>

                            <h3 class="text-zinc-500">No Task Created.</h3>

                            <% } %>

        </div>
    </div>
</body>

</html>